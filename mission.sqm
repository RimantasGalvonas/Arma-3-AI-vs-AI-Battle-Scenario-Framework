			name="afterSpawnWrapperAirfield";
			init="afterSpawnWrapperAirfieldFunction = {  " \n "    params [""_group"", ""_spawner"", ""_placer""];  " \n "    [_group, _spawner, _placer] call ForceThrough_fnc_afterSpawnAirfieldCallback;  " \n "};";
			id=137;
