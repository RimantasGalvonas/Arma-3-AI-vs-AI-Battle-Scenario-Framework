		};
		class Item42
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={6979.52,125.494,13018.316};
				angles[]={6.1558781,0,0.050622065};
			};
			title="Airfield spawners creation script";
			description="private _airfields = []; " \n " " \n "private _addAirfieldData = { " \n "    params [""_airfieldConfig""]; " \n " " \n "    private _ilsTaxiIn = getArray (_airfieldConfig >> ""ilsTaxiIn""); " \n " " \n "    if (count _ilsTaxiIn < 4) exitWith {}; // Less than two waypoints - not enough to get direction " \n " " \n "    private _taxiInWaypoint1 = [_ilsTaxiIn select 0, _ilsTaxiIn select 1, 0]; // Must start at the first waypoints. If you try to put them closer to the runway, they turn around " \n "    private _taxiInWaypoint2 = [_ilsTaxiIn select 2, _ilsTaxiIn select 3, 0]; " \n " " \n "    private _airfieldData = createHashMapFromArray [ " \n "        [""taxiStartPos"", _taxiInWaypoint1], " \n "        [""taxiDirection"", _taxiInWaypoint1 getDir _taxiInWaypoint2], " \n "        [""ilsPos"", getArray (_airfieldConfig >> ""ilsPosition"")] " \n "    ]; " \n " " \n "    _airfields append [_airfieldData]; " \n "}; " \n " " \n " " \n "[configfile >> ""CfgWorlds"" >> worldName] call _addAirfieldData; " \n " " \n " " \n "{ " \n "    [_x] call _addAirfieldData; " \n "} forEach (""true"" configClasses (configFile >> ""cfgWorlds"" >> worldName >> ""secondaryAirports"")); " \n " " \n " " \n " " \n "private _airfieldPlacerInitFormat = ""this setVariable [""""logicType"""", """"placer""""]; " \n "this setVariable [""""spawners"""", [%1]]; " \n "this setVariable [""""dynamic"""", false]; " \n "this setVariable [""""scalable"""", false]; " \n "this setVariable [""""minSpawnRadius"""", 0]; " \n "this setVariable [""""maxSpawnRadius"""", 1]; " \n "this setVariable [""""taxiDirection"""", %2]; " \n "this setVariable [""""ilsPos"""", %3]; " \n "if (isNil """"ForceThrough_fnc_airfieldUnitsManagementProcesses"""") then { " \n "    ForceThrough_fnc_airfieldUnitsManagementProcesses = createHashMap; " \n "}; " \n " " \n "ForceThrough_fnc_airfieldUnitsManagementProcesses set [ " \n "    str this, " \n "    [this] spawn ForceThrough_fnc_airfieldUnitsManagementProcess " \n "];""; " \n " " \n "private _airfieldSpawnerInit = ""this setVariable [""""logicType"""", """"spawner""""]; " \n "this setVariable [""""maxUnitsPerGroup"""", 8]; " \n "this setVariable [""""spawnRate"""", 60]; " \n "this setVariable [""""maxUnits"""", 1]; " \n " " \n "private _pool1 = createHashMapFromArray [ " \n "    [""""groups"""", [ " \n " " \n "    ]], " \n "    [""""weight"""", 10], " \n "    [""""vehicleCrewGrouping"""", true] " \n "]; " \n " " \n " " \n "this setVariable [""""pools"""", [_pool1]]; " \n " " \n "this setVariable [ " \n "    """"callback"""", " \n "    { " \n "        _this call afterSpawnWrapperAirfieldFunction; " \n "    } " \n "];""; " \n " " \n " " \n " " \n "private _allLogics = all3DENEntities select 3; " \n " " \n "private _patrolCenter = _allLogics select {((_x get3DENAttribute ""name"") select 0) == ""patrolCenter""} select 0; " \n " " \n "private _spawnerSearchString = ""this setVariable [""""logicType"""", """"spawner""""]""; " \n " " \n "private _allSpawners = _allLogics select {_spawnerSearchString in ((_x get3DENAttribute ""init"") select 0)}; " \n " " \n "private _airfieldsLayer = -1 add3DENLayer ""Airfields""; " \n " " \n " " \n " " \n "{ " \n "    private _airfieldData = _x; " \n "    private _taxiStartPos = _airfieldData get ""taxiStartPos""; " \n "    private _taxiDir = _airfieldData get ""taxiDirection""; " \n "    private _ilsPos = _airfieldData get ""ilsPos""; " \n "    _taxiStartPos set [2, 0]; " \n " " \n "    private _placerName = ""placer_airfield_"" + str (_forEachIndex + 1); " \n " " \n "    private _spawnerIndex = count _allSpawners + _forEachIndex + 1; " \n "    if (_spawnerIndex < 10) then { " \n "        _spawnerIndex = ""0"" + str _spawnerIndex; " \n "    } else { " \n "        _spawnerIndex = str _spawnerIndex; " \n "    }; " \n " " \n "    private _spawnerName = format [""spawner_%1_airfield"", _spawnerIndex]; " \n " " \n "    private _thisLayer = _airfieldsLayer add3DENLayer (""Airfield_"" + str (_forEachIndex + 1)); " \n " " \n "    private _placer = create3DENEntity [""Logic"", ""Logic"", _taxiStartPos getPos [5, _taxiDir + 180]]; " \n "    _placer set3DENAttribute [""Name"", _placerName]; " \n "    _placer set3DENAttribute [""init"", format [_airfieldPlacerInitFormat, _spawnerName, _taxiDir, _ilsPos]]; " \n "    _placer set3DENLayer _thisLayer; " \n " " \n "    add3DENConnection [""Sync"", [_placer], _patrolCenter]; " \n " " \n "    private _spawner = create3DENEntity [""Logic"", ""Logic"", _taxiStartPos]; " \n "    _spawner set3DENAttribute [""Name"", _spawnerName]; " \n "    _spawner set3DENAttribute [""init"", _airfieldSpawnerInit]; " \n "    _spawner set3DENLayer _thisLayer; " \n " " \n " " \n "} forEach _airfields;";
			id=165;
			atlOffset=0.00035858154;
		};
